---
import { navItems, site } from '../data/site';
import { sitePath } from '../utils/paths';

const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const logoSrc = `${baseUrl}assets/homestead-keeper-logo.png`;
---

<header class="site-header">
  <a class="brand" href={sitePath('/')} aria-label="Homestead Keeper home">
    <img src={logoSrc} alt="Homestead Keeper logo" width="44" height="44" />
    <span>{site.name}</span>
  </a>
  <nav aria-label="Main navigation">
    {navItems.map((item) => <a href={sitePath(item.href)}>{item.label}</a>)}
  </nav>
</header>
