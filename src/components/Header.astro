---
import { navItems, site } from '../data/site';
import { assetPath, sitePath } from '../utils/paths';
const currentPath = Astro.url.pathname.replace(import.meta.env.BASE_URL, '/') || '/';
---

<header class="site-header">
  <a class="brand" href={sitePath('/')} aria-label="Homestead Keeper home">
    <img src={assetPath('assets/homestead-keeper-logo.png')} alt="" width="44" height="44" />
    <span>{site.name}</span>
  </a>
  <nav class="main-nav" aria-label="Main navigation">
    {navItems.map((item) => {
      const active = item.href === '/' ? currentPath === '/' : currentPath.startsWith(item.href);
      return <a aria-current={active ? 'page' : undefined} href={sitePath(item.href)}>{item.label}</a>;
    })}
  </nav>
</header>
