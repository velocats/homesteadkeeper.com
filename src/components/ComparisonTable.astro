---
const rows = [
  ['Overall focus', 'Whole-homestead and small-property records', 'Often livestock, production, or farm-business focused'],
  ['Primary experience', 'iPhone, iPad, and Mac app', 'Many are browser-first dashboards'],
  ['Account model', 'No Homestead Keeper account required; local-first with optional iCloud sync', 'Often account-required cloud systems'],
  ['Growing records', 'Garden and orchard layouts alongside planting and harvest history', 'Often record lists or production logs'],
  ['Property organization', 'Places and map organization for real buildings, beds, coops, systems, and storage areas', 'Often flatter item or asset lists'],
  ['Pricing shape', 'Free tier plus monthly, yearly, or one-time lifetime unlock options', 'Many are subscription-only tools'],
];
---

<div class="table-wrap">
  <table>
    <caption>Homestead records without farm software complexity</caption>
    <thead>
      <tr>
        <th scope="col">Need</th>
        <th scope="col">Homestead Keeper</th>
        <th scope="col">Typical farm software</th>
      </tr>
    </thead>
    <tbody>
      {rows.map((row) => (
        <tr>
          {row.map((cell, index) => index === 0 ? <th scope="row">{cell}</th> : <td>{cell}</td>)}
        </tr>
      ))}
    </tbody>
  </table>
</div>
