---
const rows = [
  ['No Homestead Keeper login', 'Yes', 'Yes', 'Often no'],
  ['Data on Apple devices', 'Yes', 'Yes', 'Often cloud-dashboard first'],
  ['iCloud sync across Apple devices', 'Yes', 'Yes', 'Varies'],
  ['Works offline', 'Yes', 'Yes', 'Often limited'],
  ['Total items', 'Up to 20', 'Unlimited', 'Varies'],
  ['Logbook and reminders', 'Yes', 'Yes', 'Varies'],
  ['PDF and CSV exports', 'No', 'Yes', 'Often paid'],
  ['Backup export and restore/import', 'No', 'Yes', 'Varies'],
  ['QR label printing/export', 'No', 'Yes', 'Rare'],
  ['Lifetime option', 'No', 'Yes', 'Uncommon'],
];
---

<div class="table-wrap">
  <table>
    <caption>Homestead Keeper Free vs Pro vs typical farm software</caption>
    <thead>
      <tr>
        <th>Capability</th>
        <th>Free</th>
        <th>Pro</th>
        <th>Typical farm software</th>
      </tr>
    </thead>
    <tbody>
      {rows.map((row) => (
        <tr>
          {row.map((cell, index) => index === 0 ? <th scope="row">{cell}</th> : <td>{cell}</td>)}
        </tr>
      ))}
    </tbody>
  </table>
</div>
