---
interface Card {
  title: string;
  href?: string;
  summary: string;
}

interface Props {
  cards: Card[];
}

const { cards } = Astro.props;
---

<div class="card-grid">
  {cards.map((card) => (
    <article class="feature-card">
      <h3>{card.href ? <a href={card.href}>{card.title}</a> : card.title}</h3>
      <p>{card.summary}</p>
    </article>
  ))}
</div>
