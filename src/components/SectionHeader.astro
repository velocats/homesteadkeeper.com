---
interface Props { eyebrow?: string; title: string; body?: string; headingId?: string; }
const { eyebrow, title, body, headingId } = Astro.props;
---
<div class="section-header">
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2 id={headingId}>{title}</h2>
  {body && <p class="lede">{body}</p>}
</div>
