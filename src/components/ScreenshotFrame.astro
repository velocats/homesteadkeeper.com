---
import { assetPath } from '../utils/paths';
interface Props { src?: string; alt?: string; caption?: string; loading?: 'lazy' | 'eager'; }
const { src = 'assets/screenshots/homestead-hub.webp', alt = 'Homestead Keeper Homestead Hub showing featured garden, animals, property, inventory, and other homestead areas.', caption = 'Homestead Hub, the home base for your garden, animals, property, inventory, and records.', loading = 'lazy' } = Astro.props;
const imageUrl = assetPath(src);
---
<figure class="screenshot-frame">
  <a class="device-shell" href={imageUrl} target="_blank" rel="noopener" aria-label={`Open larger screenshot: ${alt}`}>
    <img src={imageUrl} alt={alt} loading={loading} />
  </a>
  {caption && <figcaption>{caption} <span>Click to expand.</span></figcaption>}
</figure>
