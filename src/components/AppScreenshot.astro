---
import { assetPath } from '../utils/paths';

interface Props {
  src: string;
  alt: string;
  title?: string;
  body?: string;
  class?: string;
  loading?: 'lazy' | 'eager';
}

const { src, alt, title, body, class: className = '', loading = 'lazy' } = Astro.props;
const imageUrl = assetPath(src);
---

<figure class:list={['app-screenshot', className]}>
  <button
    class="screenshot-trigger"
    type="button"
    data-lightbox-src={imageUrl}
    data-lightbox-alt={alt}
    data-lightbox-title={title ?? alt}
    aria-label={`Expand screenshot: ${title ?? alt}`}
  >
    <img src={imageUrl} alt={alt} loading={loading} />
  </button>
  {(title || body) && (
    <figcaption>
      {title && <strong>{title}</strong>}
      {body && <span>{body}</span>}
      <em>Click to expand</em>
    </figcaption>
  )}
</figure>
