---
import { proFeatures } from '../data/site';
---

<div class="pricing-grid">
  <article class="pricing-card">
    <p class="eyebrow">Free</p>
    <h3>Try it with real records</h3>
    <p class="price">$0</p>
    <p>A practical way to try Homestead Keeper before adding your whole homestead.</p>
    <ul>
      <li>Up to 20 total items</li>
      <li>Calendar, reminders, and Field Log entries</li>
      <li>Cedar Ridge demo data</li>
      <li>Data on your Apple devices</li>
      <li>Upgrade for unlimited items and paid exports</li>
    </ul>
  </article>
  <article class="pricing-card featured">
    <p class="eyebrow">Pro</p>
    <h3>Whole-homestead toolkit</h3>
    <div class="price-stack">
      <p><strong>$2.99</strong><span>/month</span></p>
      <p><strong>$19.99</strong><span>/year</span></p>
      <p><strong>$39.99</strong><span>lifetime</span></p>
    </div>
    <p>Monthly, yearly, or one-time lifetime access. All paid plans unlock the same Pro features.</p>
    <ul>
      {proFeatures.map((feature) => <li>{feature}</li>)}
    </ul>
  </article>
</div>
