---
import { existsSync } from 'node:fs';
import { fileURLToPath } from 'node:url';

interface Props {
  label: string;
  aspect?: string;
  src?: string;
}

const { label, aspect = '4 / 3', src } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const assetSrc = src ? `${baseUrl}${src.replace(/^\//, '')}` : undefined;
const publicFile = src ? fileURLToPath(new URL(`../../public/${src.replace(/^\//, '')}`, import.meta.url)) : undefined;
const hasImage = Boolean(publicFile && existsSync(publicFile));
---

<figure class="screenshot-frame" style={`--aspect:${aspect}`}>
  {
    hasImage && assetSrc ? (
      <button
        class="device-shell screenshot-trigger"
        type="button"
        data-lightbox-src={assetSrc}
        data-lightbox-alt={`${label} screenshot`}
        data-lightbox-title={label}
        aria-label={`Expand screenshot: ${label}`}
      >
        <img src={assetSrc} alt={`${label} screenshot`} loading="lazy" />
      </button>
    ) : (
      <div role="img" aria-label={`Planned app screen: ${label}`}>
        <span>{label}</span>
        <small>Screen preview unavailable</small>
      </div>
    )
  }
  <figcaption>{label}</figcaption>
</figure>
