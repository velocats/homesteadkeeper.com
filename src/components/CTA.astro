---
import { sitePath } from '../utils/paths';
import { site } from '../data/site';
interface Props { title?: string; body?: string; primaryLabel?: string; primaryHref?: string; secondaryLabel?: string; secondaryHref?: string; }
const {
  title = 'Ready to bring your records together?',
  body = 'Homestead Keeper is being built for people who need calm, practical records for animals, gardens, equipment, inventory, property systems, and seasonal work.',
  primaryLabel = site.appStoreLabel,
  primaryHref = site.appStoreUrl,
  secondaryLabel = 'View features',
  secondaryHref = '/features',
} = Astro.props;
---
<section class="cta-band" aria-labelledby="cta-title">
  <div>
    <p class="eyebrow">Homestead Keeper</p>
    <h2 id="cta-title">{title}</h2>
    <p>{body}</p>
  </div>
  <div class="button-row">
    <a class="button primary" href={sitePath(primaryHref)}>{primaryLabel}</a>
    <a class="button secondary" href={sitePath(secondaryHref)}>{secondaryLabel}</a>
  </div>
</section>
