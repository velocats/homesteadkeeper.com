---
import { site } from '../data/site';
import { sitePath } from '../utils/paths';

interface Props {
  title?: string;
  text?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}

const {
  title = 'Ready to get organized?',
  text = 'Try the Free plan with real records, then upgrade when your homestead needs the long-term toolkit.',
  primaryLabel = 'Try Homestead Keeper',
  primaryHref = site.appStoreUrl,
  secondaryLabel = 'View pricing',
  secondaryHref = '/pricing',
} = Astro.props;
---

<section class="cta-band">
  <div>
    <h2>{title}</h2>
    <p>{text}</p>
  </div>
  <div class="button-row">
    <a class="button primary" href={primaryHref}>{primaryLabel}</a>
    <a class="button secondary" href={sitePath(secondaryHref)}>{secondaryLabel}</a>
  </div>
</section>
