---
import { footerFeatureLinks, site } from '../data/site';
import { sitePath } from '../utils/paths';

const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const logoSrc = `${baseUrl}assets/homestead-keeper-logo.png`;
---

<footer class="site-footer">
  <div class="footer-grid">
    <div>
      <a class="brand footer-brand" href={sitePath('/')}>
        <img src={logoSrc} alt="Homestead Keeper logo" width="38" height="38" />
        <span>{site.name}</span>
      </a>
      <p>{site.tagline}</p>
      <p>Local-first. No account. No subscription required to get started.</p>
    </div>
    <div>
      <h2>Features</h2>
      {footerFeatureLinks.map((item) => <a href={sitePath(item.href)}>{item.title}</a>)}
    </div>
    <div>
      <h2>Company</h2>
      <a href={sitePath('/pricing')}>Pricing</a>
      <a href={sitePath('/playbook')}>Playbook</a>
      <a href={sitePath('/support')}>Support</a>
      <a href={sitePath('/privacy')}>Privacy</a>
    </div>
    <div>
      <h2>Contact</h2>
      <a href={`mailto:${site.supportEmail}`}>{site.supportEmail}</a>
    </div>
  </div>
  <p class="copyright">© {new Date().getFullYear()} Homestead Keeper. All rights reserved.</p>
</footer>
