---
import { featureLinks, site } from '../data/site';

const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const logoSrc = `${baseUrl}assets/homestead-keeper-logo.png`;
---

<footer class="site-footer">
  <div class="footer-grid">
    <div>
      <a class="brand footer-brand" href="/">
        <img src={logoSrc} alt="Homestead Keeper logo" width="38" height="38" />
        <span>{site.name}</span>
      </a>
      <p>{site.tagline}</p>
      <p>Local-first. No account. No subscription required to get started.</p>
    </div>
    <div>
      <h2>Features</h2>
      {featureLinks.map((item) => <a href={item.href}>{item.title}</a>)}
    </div>
    <div>
      <h2>Company</h2>
      <a href="/pricing">Pricing</a>
      <a href="/playbook">Playbook</a>
      <a href="/support">Support</a>
      <a href="/privacy">Privacy</a>
    </div>
    <div>
      <h2>Social</h2>
      <a href="https://instagram.com/homesteadkeeper" aria-label="Instagram placeholder">Instagram placeholder</a>
      <a href="https://youtube.com/@homesteadkeeper" aria-label="YouTube placeholder">YouTube placeholder</a>
      <a href={`mailto:${site.supportEmail}`}>{site.supportEmail}</a>
    </div>
  </div>
  <p class="copyright">© {new Date().getFullYear()} Homestead Keeper. All rights reserved.</p>
</footer>
