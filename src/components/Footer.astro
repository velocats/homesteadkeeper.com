---
import { site } from '../data/site';
import { assetPath, sitePath } from '../utils/paths';

const footerLinks = [
  [site.appStoreLabel, site.appStoreUrl],
  ['Features', '/features'],
  ['Use Cases', '/use-cases'],
  ['Workflows', '/workflows'],
  ['Pricing', '/pricing'],
  ['FAQ', '/faq'],
  ['Privacy', '/privacy'],
  ['Support', '/support'],
];
const featureLinks = [
  ['Chicken Keepers', '/use-cases/chicken-keepers'],
  ['Gardeners', '/use-cases/gardeners'],
  ['Hobby Farms', '/use-cases/hobby-farms'],
  ['Rural Property', '/use-cases/rural-property-owners'],
  ['Pantry Inventory', '/use-cases/pantry-inventory'],
  ['Garden Beds', '/features/garden'],
  ['Animals', '/features/animals'],
  ['Inventory', '/features/inventory'],
  ['Mac App', '/features/macos'],
];
---

<footer class="site-footer">
  <div class="footer-grid">
    <section aria-label="About Homestead Keeper">
      <a class="brand footer-brand" href={sitePath('/')}>
        <img src={assetPath('assets/homestead-keeper-logo.png')} alt="" width="40" height="40" />
        <span>{site.name}</span>
      </a>
      <p>{site.tagline}</p>
      <p>No Homestead Keeper login. Data on your Apple devices. Optional iCloud sync across iPhone, iPad, and Mac.</p>
    </section>
    <nav aria-labelledby="footer-product-title">
      <h2 id="footer-product-title">Product</h2>
      <div class="footer-link-list">
        {footerLinks.map(([label, href]) => <a href={sitePath(href)}>{label}</a>)}
      </div>
    </nav>
    <nav aria-labelledby="footer-tracks-title">
      <h2 id="footer-tracks-title">Use cases</h2>
      <div class="footer-link-list">
        {featureLinks.map(([label, href]) => <a href={sitePath(href)}>{label}</a>)}
      </div>
    </nav>
    <section aria-labelledby="footer-contact-title">
      <h2 id="footer-contact-title">Contact</h2>
      <a href={sitePath(site.appStoreUrl)}>{site.appStoreLabel}</a>
      <a href={`mailto:${site.supportEmail}`}>{site.supportEmail}</a>
      <p class="fine-print">Available on the App Store for iPhone, iPad, and Mac. Pricing shown on this site reflects the current App Store options.</p>
    </section>
  </div>
  <p class="copyright">© {new Date().getFullYear()} Homestead Keeper. All rights reserved.</p>
</footer>
