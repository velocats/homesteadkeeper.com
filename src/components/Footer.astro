---
import { site } from '../data/site';
import { assetPath, sitePath } from '../utils/paths';

const footerLinks = [
  ['Features', '/features'],
  ['Pricing', '/pricing'],
  ['FAQ', '/faq'],
  ['Privacy', '/privacy'],
  ['Support', '/support'],
];
const featureLinks = ['Animals', 'Garden', 'Inventory', 'Equipment', 'Reports', 'Places'];
---

<footer class="site-footer">
  <div class="footer-grid">
    <section aria-label="About Homestead Keeper">
      <a class="brand footer-brand" href={sitePath('/')}>
        <img src={assetPath('assets/homestead-keeper-logo.png')} alt="" width="40" height="40" />
        <span>{site.name}</span>
      </a>
      <p>{site.tagline}</p>
      <p>A local-first homestead tracker for Apple devices — practical records without a required cloud dashboard.</p>
    </section>
    <section>
      <h2>Product</h2>
      {footerLinks.map(([label, href]) => <a href={sitePath(href)}>{label}</a>)}
    </section>
    <section>
      <h2>Tracks</h2>
      {featureLinks.map((label) => <a href={sitePath('/features')}>{label}</a>)}
    </section>
    <section>
      <h2>Contact</h2>
      <a href={`mailto:${site.supportEmail}`}>{site.supportEmail}</a>
      <p class="fine-print">App Store listing and final pricing are still in progress.</p>
    </section>
  </div>
  <p class="copyright">© {new Date().getFullYear()} Homestead Keeper. All rights reserved.</p>
</footer>
