---
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { assetPath } from '../utils/paths';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  path?: string;
  image?: string;
  jsonLd?: Record<string, unknown>;
}

const { title, description, path = '/', image, jsonLd } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#f7eddc" />
    <link rel="icon" type="image/png" href={assetPath('favicon.png')} />
    <SEO title={title} description={description} path={path} image={image} jsonLd={jsonLd} />
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <Header />
    <main id="content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
