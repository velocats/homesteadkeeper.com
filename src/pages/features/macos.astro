---
import Layout from '../../layouts/Layout.astro';
import CTA from '../../components/CTA.astro';
import AppScreenshot from '../../components/AppScreenshot.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import { sitePath } from '../../utils/paths';

const title = 'Homestead Keeper for Mac';
const description = 'Homestead Keeper for Mac gives you more room to review records, reports, calendars, inventory, production, and property work on a larger screen.';

const macScreenshots = [
  {
    src: 'assets/screenshots/macOS/mac-homestead-hub.png',
    title: 'Homestead Hub',
    body: 'Garden, animals, property, inventory, and more in one desktop view.',
    alt: 'Homestead Keeper for Mac showing the Homestead Hub with garden, animals, property, and inventory areas.',
  },
  {
    src: 'assets/screenshots/macOS/mac-today-screen.png',
    title: 'Today Screen',
    body: 'Chores, overdue work, quick field logs, and needs-attention items.',
    alt: 'Homestead Keeper for Mac Today Screen showing chores, overdue tasks, and needs-attention items.',
  },
  {
    src: 'assets/screenshots/macOS/mac-garden-bed-layout.png',
    title: 'Garden Bed Layout',
    body: 'Visual crop placement by bed, row, season, and planting log.',
    alt: 'Homestead Keeper for Mac garden bed layout showing crop placement by bed and season.',
  },
  {
    src: 'assets/screenshots/macOS/mac-calendar.png',
    title: 'Calendar',
    body: 'Month view for chores, crop dates, animal care, reminders, and seasonal work.',
    alt: 'Homestead Keeper for Mac calendar month view with chores, crop dates, and seasonal reminders.',
  },
  {
    src: 'assets/screenshots/macOS/mac-garden-timeline.png',
    title: 'Garden Timeline',
    body: 'Planting, growing, harvest windows, frost dates, and today markers.',
    alt: 'Homestead Keeper for Mac garden timeline showing planting, growing, and harvest windows with frost dates.',
  },
  {
    src: 'assets/screenshots/macOS/mac-inventory.png',
    title: 'Inventory',
    body: 'Supplies, feed, seeds, medicine, low stock, locations, and expirations.',
    alt: 'Homestead Keeper for Mac inventory view showing supplies, feed, seeds, and expiration dates.',
  },
  {
    src: 'assets/screenshots/macOS/mac-production-trends.png',
    title: 'Production Trends',
    body: 'Eggs, milk, honey, harvest totals, and production charts.',
    alt: 'Homestead Keeper for Mac production trends showing egg, milk, honey, and harvest totals with charts.',
  },
  {
    src: 'assets/screenshots/macOS/mac-animal-feed-costs.png',
    title: 'Animal Feed Costs',
    body: 'Feed spending, quantities, events, and costs grouped by animal.',
    alt: 'Homestead Keeper for Mac animal feed costs showing feed spending and quantities grouped by animal.',
  },
  {
    src: 'assets/screenshots/macOS/mac-equipment-records.png',
    title: 'Equipment Records',
    body: 'Service history, repairs, inspections, costs, vendors, and notes.',
    alt: 'Homestead Keeper for Mac equipment records showing service history, repairs, and inspection notes.',
  },
  {
    src: 'assets/screenshots/macOS/mac-warranty-countdown.png',
    title: 'Warranty Countdown',
    body: 'Expired, upcoming, and later warranty or readiness dates.',
    alt: 'Homestead Keeper for Mac warranty countdown showing expired, upcoming, and later warranty dates.',
  },
];
---

<Layout title={title} description={description} path="/features/macos" image="/assets/screenshots/macOS/mac-homestead-hub.png">
  <section class="page-hero">
    <p class="eyebrow">Mac app</p>
    <h1>Homestead Keeper for Mac.</h1>
    <p class="lede">Use the larger screen to review records, reports, calendars, inventory, production, and property work.</p>
  </section>

  <section class="split-section">
    <div>
      <h2>More room for the records that matter.</h2>
      <p>The Mac app gives you a wider view for browsing inventory, scanning reports, reading timelines, and reviewing production history without scrolling through a phone screen.</p>
      <ul class="check-list">
        <li>More room for reports and review</li>
        <li>Easier browsing of inventory, records, and timelines</li>
        <li>Useful for planning, reviewing, and organizing homestead information</li>
        <li>Works as part of the same iPhone, iPad, and Mac Apple-device app</li>
      </ul>
      <p>No separate Mac login or sync setup. Enable iCloud in your Apple settings and records stay consistent across devices.</p>
    </div>
    <div>
      <p class="eyebrow">One app. Three screens.</p>
      <p>No Homestead Keeper login. Records on your Apple devices. Optional iCloud sync across iPhone, iPad, and Mac.</p>
      <p><a class="button secondary" href={sitePath('/pricing')}>View Pricing</a></p>
    </div>
  </section>

  <section class="section" aria-labelledby="macos-gallery-title">
    <SectionHeader
      headingId="macos-gallery-title"
      eyebrow="Mac app gallery"
      title="Desktop views for deeper review."
      body="Click any screenshot to open the full-resolution image on the page."
    />
    <div class="screenshot-gallery macos-gallery">
      {macScreenshots.map((shot) => <AppScreenshot {...shot} />)}
    </div>
  </section>

  <CTA title="A whole-homestead app for Apple devices." body="Homestead Keeper is designed for iPhone, iPad, and Mac, with local-first records and optional iCloud sync." primaryLabel="View all features" primaryHref="/features" secondaryLabel="See workflows" secondaryHref="/workflows" />
</Layout>
