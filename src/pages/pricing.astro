---
import Layout from '../layouts/Layout.astro';
import PricingCards from '../components/PricingCards.astro';
import ComparisonTable from '../components/ComparisonTable.astro';
import CTA from '../components/CTA.astro';
import { site } from '../data/site';

const description = 'Homestead Keeper pricing: Free for up to 5 real assets, with Pro monthly, yearly, and lifetime options for unlimited assets, exports, backups, QR label printing, documents, and advanced schedules.';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: site.name,
  applicationCategory: 'LifestyleApplication',
  operatingSystem: 'iOS, iPadOS, macOS',
  offers: [
    { '@type': 'Offer', name: 'Free', price: '0', priceCurrency: 'USD' },
    { '@type': 'Offer', name: 'Pro Monthly', price: '1.99', priceCurrency: 'USD' },
    { '@type': 'Offer', name: 'Pro Yearly', price: '14.99', priceCurrency: 'USD' },
    { '@type': 'Offer', name: 'Pro Lifetime', price: '29.99', priceCurrency: 'USD' },
  ],
};
---

<Layout title="Pricing | Homestead Keeper" description={description} path="/pricing" jsonLd={jsonLd}>
  <section class="page-hero">
    <p class="eyebrow">Pricing</p>
    <h1>Free to start, Pro when you need the full toolkit</h1>
    <p class="lede">Homestead Keeper is a farm management app with no subscription required to get started. Use Free for a small set of real assets, then choose monthly, yearly, or lifetime Pro access when your records grow.</p>
  </section>

  <section class="section">
    <PricingCards />
  </section>

  <section class="section rich-copy">
    <p class="eyebrow">What Pro unlocks</p>
    <h2>Built for long-term records</h2>
    <p class="section-intro">Pro unlocks unlimited assets, PDF and CSV exports, backup and restore, QR label printing, document attachments, and advanced recurring schedules. Lifetime gives users a one-time purchase option with no ongoing cost required.</p>
    <a class="button primary" href={site.appStoreUrl}>Download Free → Try it first, upgrade when ready</a>
  </section>

  <section class="section">
    <ComparisonTable />
  </section>

  <CTA />
</Layout>
