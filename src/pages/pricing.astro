---
import Layout from '../layouts/Layout.astro';
import PricingCards from '../components/PricingCards.astro';
import ComparisonTable from '../components/ComparisonTable.astro';
import CTA from '../components/CTA.astro';
import { site } from '../data/site';

const description = 'Homestead Keeper pricing: Free for up to 5 real assets, with planned/current Pro monthly, yearly, and lifetime options for unlimited assets, exports, backups, QR labels, documents, and advanced schedules.';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: site.name,
  applicationCategory: 'LifestyleApplication',
  operatingSystem: 'iOS, iPadOS, macOS',
  offers: [
    { '@type': 'Offer', name: 'Free', price: '0', priceCurrency: 'USD' },
    { '@type': 'Offer', name: 'Pro Monthly', price: '1.99', priceCurrency: 'USD' },
    { '@type': 'Offer', name: 'Pro Yearly', price: '14.99', priceCurrency: 'USD' },
    { '@type': 'Offer', name: 'Pro Lifetime', price: '29.99', priceCurrency: 'USD' },
  ],
};
---

<Layout title="Pricing | Homestead Keeper" description={description} path="/pricing" jsonLd={jsonLd}>
  <section class="page-hero">
    <p class="eyebrow">Pricing</p>
    <h1>Free to try, Pro for long-term records</h1>
    <p class="lede">Free is for trying Homestead Keeper with real records. Pro is for long-term homestead record keeping across unlimited animals, inventory, property, reports, exports, backups, documents, QR labels, and advanced schedules.</p>
  </section>

  <section class="section">
    <PricingCards />
    <p class="pricing-note">Prices shown are planned/current and may vary by App Store region.</p>
  </section>

  <section class="section rich-copy">
    <p class="eyebrow">Choosing a plan</p>
    <h2>Pick the way you prefer to keep records</h2>
    <div class="report-grid">
      <article class="report-card"><h3>Free</h3><p>Best for testing the app with up to 5 real assets, unlimited logbook entries and reminders, calendar and report viewing, Cedar Ridge demo data, and QR code viewing.</p></article>
      <article class="report-card"><h3>Pro Monthly</h3><p>Good when you want the full toolkit without a long commitment.</p></article>
      <article class="report-card"><h3>Pro Yearly</h3><p>Good for ongoing homestead records at the lowest subscription price.</p></article>
      <article class="report-card"><h3>Pro Lifetime</h3><p>Good for people who prefer a one-time purchase for a long-lived homestead logbook.</p></article>
    </div>
  </section>

  <section class="section">
    <ComparisonTable />
  </section>

  <CTA />
</Layout>
