---
import Layout from '../layouts/Layout.astro';
import CTA from '../components/CTA.astro';
import PricingCard from '../components/PricingCard.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { pricingTiers } from '../data/site';

const title = 'Pricing | Homestead Keeper';
const description = 'Homestead Keeper pricing will be simple and honest, with a free starter option and a full unlock for whole-homestead records. Final App Store pricing is still being finalized.';
---

<Layout title={title} description={description} path="/pricing">
  <section class="page-hero narrow">
    <p class="eyebrow">Pricing</p>
    <h1>Simple pricing for practical homestead records.</h1>
    <p class="lede">Final App Store pricing is not locked yet. This page keeps the structure clear without inventing prices before launch.</p>
  </section>

  <section class="section">
    <div class="pricing-grid">
      {pricingTiers.map((tier) => <PricingCard {...tier} />)}
    </div>
  </section>

  <section class="split-section soft-panel">
    <div>
      <p class="eyebrow">Honest scope</p>
      <h2>Pay for useful records, not cloud overhead.</h2>
      <p>Homestead Keeper is not being positioned as a farm ERP suite, enterprise dashboard, or accounting system. It is a local-first app for keeping better records of the work already happening around a homestead.</p>
    </div>
    <div class="callout-card">
      <h3>Before launch</h3>
      <p>Replace the placeholder pricing with exact App Store pricing only when the product decision is final. Avoid promising sync, cloud sharing, or business features unless they exist in the released app.</p>
    </div>
  </section>

  <CTA primaryLabel="Compare features" primaryHref="/features" secondaryLabel="Read FAQ" secondaryHref="/faq" />
</Layout>
