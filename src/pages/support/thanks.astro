---
import Layout from '../../layouts/Layout.astro';
import CTA from '../../components/CTA.astro';
import { site } from '../../data/site';

const title = 'Thanks | Homestead Keeper Support';
const description = 'Thanks for contacting Homestead Keeper support.';
---

<Layout title={title} description={description} path="/support/thanks">
  <section class="page-hero narrow">
    <p class="eyebrow">Message sent</p>
    <h1>Thanks for contacting Homestead Keeper.</h1>
    <p class="lede">Your message was sent to support. If you need to add screenshots or extra detail, you can also email <a class="text-link" href={`mailto:${site.supportEmail}`}>{site.supportEmail}</a>.</p>
  </section>

  <CTA title="Keep exploring" body="While you wait for a reply, the FAQ and workflows may answer common setup and record-keeping questions." primaryLabel="Read FAQ" primaryHref="/faq" secondaryLabel="View workflows" secondaryHref="/workflows" />
</Layout>
