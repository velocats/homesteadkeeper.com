---
import Layout from '../layouts/Layout.astro';
import CTA from '../components/CTA.astro';

const title = 'Privacy and Local-First Design | Homestead Keeper';
const description = 'Homestead Keeper is designed as a local-first homestead app with no required web dashboard, no required hosted account for day-to-day records, user-owned records, and no unnecessary cloud complexity.';
const principles = [
  ['Local-first records', 'Day-to-day homestead records are designed to live on your Apple device instead of depending on a required Homestead Keeper cloud dashboard.'],
  ['No required web account', 'The app is intended to be useful without forcing a hosted login for normal record keeping.'],
  ['User-owned records', 'Your animal, garden, equipment, inventory, property, and report history should stay under your control.'],
  ['No unnecessary cloud complexity', 'The product direction favors practical local records, backups, and exports over heavy cloud administration.'],
  ['No sale of user data', 'Homestead Keeper is not designed around selling user data or behavioral ad profiles.'],
  ['No invented sync promises', 'Any future sync, sharing, or cloud behavior should be described only when it actually exists in the released app.'],
];
---

<Layout title={title} description={description} path="/privacy">
  <section class="page-hero narrow">
    <p class="eyebrow">Privacy</p>
    <h1>Local-first by design.</h1>
    <p class="lede">Homestead Keeper is built for people who want useful animal, garden, inventory, equipment, property, and seasonal records without a required cloud dashboard.</p>
  </section>

  <section class="section">
    <div class="card-grid">
      {principles.map(([title, body]) => <article class="card"><h3>{title}</h3><p>{body}</p></article>)}
    </div>
  </section>

  <section class="split-section soft-panel">
    <div>
      <p class="eyebrow">Plain language</p>
      <h2>Your records should still be useful where signal is weak.</h2>
      <p>Homesteads include barns, shops, gardens, fields, pump houses, sheds, and rural corners where internet service is not always reliable. Homestead Keeper is designed around practical record keeping first.</p>
      <p>Local-first does not mean backups are optional. Before deleting the app, wiping a device, or replacing hardware, make sure you have a backup or export path that matches your app version.</p>
    </div>
    <div class="callout-card">
      <h3>About family sync</h3>
      <p>Do not assume shared family sync is available unless your installed version specifically says it is. The website should avoid promising cloud behavior that has not shipped.</p>
    </div>
  </section>

  <CTA primaryLabel="Read FAQ" primaryHref="/faq" secondaryLabel="View features" secondaryHref="/features" />
</Layout>
