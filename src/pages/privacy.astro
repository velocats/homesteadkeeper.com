---
import Layout from '../layouts/Layout.astro';

const promises = [
  ['No account required', 'Homestead Keeper does not require a hosted login to keep homestead records.'],
  ['Local device storage', 'Day-to-day app data is stored locally on your device.'],
  ['No sale of user data', 'Homestead Keeper does not sell user data.'],
  ['No third-party ad tracking', 'The app is not designed around ad networks, behavioral profiles, or third-party advertising trackers.'],
  ['User-controlled backups', 'Backup and restore tools are controlled by the user, and backup destinations should be chosen and protected by the user.'],
  ['Clear analytics disclosure', 'If analytics are ever added, they should be disclosed clearly before they are used.'],
];
---

<Layout title="Privacy | Homestead Keeper" description="Homestead Keeper is a local-first homestead app with no account required, local device storage, no sale of user data, no third-party ad tracking, and user-controlled backups." path="/privacy">
  <section class="page-hero">
    <p class="eyebrow">Privacy</p>
    <h1>Local-first by design</h1>
    <p class="lede">Homestead Keeper is built for people who want useful animal, garden, inventory, property, and rural care records without a required cloud account.</p>
  </section>

  <section class="section">
    <div class="privacy-grid">
      {promises.map(([title, body]) => (
        <article class="privacy-card">
          <h2>{title}</h2>
          <p>{body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section rich-copy">
    <p class="eyebrow">Plain language</p>
    <h2>What this means</h2>
    <p>Your records should remain useful in barns, gardens, shops, fields, and other places where signal is weak. Homestead Keeper does not require a Homestead Keeper cloud service for normal day-to-day record keeping.</p>
    <p>Local-first does not mean nothing can ever go wrong. Protect your device, make backups before deleting the app or replacing a device, and keep backup files in storage you trust.</p>
  </section>
</Layout>
