---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import CTA from '../components/CTA.astro';
import FeatureCards from '../components/FeatureCards.astro';
import ScreenshotPlaceholder from '../components/ScreenshotPlaceholder.astro';
import PlatformBadges from '../components/PlatformBadges.astro';
import InternalLinkCards from '../components/InternalLinkCards.astro';
import { site } from '../data/site';

const title = 'Homestead Keeper | Local-First Homestead Management App';
const description =
  'Keep your homestead running with a local-first homestead management app for animals, gardens, bees, orchards, equipment, inventory, reminders, reports, and rural property care.';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: site.name,
  applicationCategory: 'LifestyleApplication',
  operatingSystem: 'iOS, iPadOS, macOS',
  description,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
};

const managementCards = [
  { title: 'Animals', href: '/features/animals', summary: 'Profiles, care reminders, health records, breeding, pedigree, production, weight history, photos, and documents.' },
  { title: 'Garden & Harvest', href: '/features/garden', summary: 'Track beds, plantings, varieties, watering, fertilizing, pest notes, harvests, and seasonal garden history.' },
  { title: 'Bees & Hives', href: '/features/garden', summary: 'Record hive inspections, feeding, treatments, queen checks, splits, swarms, and honey harvests.' },
  { title: 'Orchard & Perennials', href: '/features/garden', summary: 'Track fruit trees, berry patches, grapevines, pruning, spraying, fertilizing, harvests, and seasonal care.' },
  { title: 'Equipment & Workshop', href: '/features', summary: 'Keep repair logs, service reminders, manuals, parts, warranty notes, fuel, filters, and maintenance history.' },
  { title: 'Property, Fences & Water', href: '/features', summary: 'Track gates, fences, wells, pumps, irrigation, buildings, storm damage, roads, and property repairs.' },
  { title: 'Inventory', href: '/features/inventory', summary: 'Watch feed, hay, bedding, seeds, medicine, vaccines, canning supplies, fuel, parts, and emergency supplies.' },
  { title: 'Food Preservation', href: '/features', summary: 'Keep notes for canning, freezing, dehydrating, fermenting, pantry storage, batch dates, and supplies.' },
  { title: 'Off-grid Systems', href: '/features', summary: 'Track generators, solar, batteries, propane, water systems, backup power, and seasonal checks.' },
  { title: 'Emergency Prep', href: '/features', summary: 'Track stored water, food, fuel, first aid, generator readiness, documents, and expiration dates.' },
  { title: 'Calendar & Reminders', href: '/features/reminders', summary: 'See overdue work, upcoming chores, breeding dates, production entries, inventory dates, and seasonal tasks.' },
  { title: 'Reports & Exports', href: '/features/reports', summary: 'Review homestead summaries, animal care, production, inventory, garden season, property handoff, and CSV/PDF exports.' },
];

const homesteadExamples = [
  { title: 'Backyard chickens + garden', summary: 'Track egg counts, coop cleaning, feed inventory, raised beds, watering, plantings, and harvests.' },
  { title: 'Rabbitry + small livestock', summary: 'Track breeding, litters, weights, treatments, pedigrees, feed, cages, and care reminders.' },
  { title: 'Bees + orchard', summary: 'Track hive inspections, queen checks, treatments, honey harvests, fruit tree pruning, sprays, and seasonal care.' },
  { title: 'Rural property care', summary: 'Track fences, gates, pumps, irrigation, buildings, equipment, repairs, and storm damage.' },
  { title: 'Food preservation + pantry', summary: 'Track harvest notes, canning batches, freezer inventory, jars, lids, and storage supplies.' },
  { title: 'Off-grid / emergency prep', summary: 'Track generators, batteries, propane, water, first aid, fuel, backup plans, and expiration checks.' },
];

const screenshotPaths = {
  home: 'assets/screenshots/home-dashboard.png',
  animal: 'assets/screenshots/animal-detail.png',
  inventory: 'assets/screenshots/inventory.png',
  reports: 'assets/screenshots/reports.png',
  calendar: 'assets/screenshots/calendar.png',
  settings: 'assets/screenshots/settings.png',
};
---

<Layout title={title} description={description} path="/" jsonLd={jsonLd}>
  <Hero
    eyebrow="Local-first homestead logbook"
    title="Keep your homestead running."
    text="Track animals, gardens, bees, orchards, equipment, inventory, chores, production, medical records, expenses, and rural property care in one local-first app for iPhone, iPad, and Mac."
    ctaLabel="Try Homestead Keeper"
    ctaHref={site.appStoreUrl}
  >
    <!-- TODO: Replace with /public/assets/screenshots/home-dashboard.png when the final Home screenshot is ready. -->
      <ScreenshotPlaceholder label="Home Dashboard" src={screenshotPaths.home} aspect="4 / 3" />
  </Hero>

  <PlatformBadges />

  <section class="section">
    <div class="trust-row" aria-label="Product principles">
      <span>No account required</span>
      <span>Works offline</span>
      <span>Local-first records</span>
      <span>iPhone, iPad, and Mac</span>
    </div>
  </section>

  <section class="section">
    <p class="eyebrow">Whole-homestead management</p>
    <h2>What you can manage</h2>
    <p class="section-intro">
      Homestead Keeper is the practical operating logbook for a real homestead: fast enough for daily capture, detailed enough for long-term records, and calm enough to use from the barn, garden, shop, field, or kitchen table.
    </p>
    <FeatureCards cards={managementCards} />
  </section>

  <section class="split-section">
    <div>
      <p class="eyebrow">Built for the whole homestead</p>
      <h2>Mixed, real-world records without the clutter</h2>
      <p class="section-intro">Homestead Keeper is designed for mixed, real-world homesteads: chickens and rabbits, gardens and orchards, hives and equipment, fences and water systems, freezers and feed bins. Start with the areas you manage today, then add more as your homestead grows.</p>
    </div>
    <aside class="sidebar-stack">
      <article class="info-card"><h3>Enable only the areas you use</h3><p>Keep the Homestead Hub focused on what you manage right now.</p></article>
      <article class="info-card"><h3>Hide areas without deleting records</h3><p>Quiet down unused areas while keeping history available.</p></article>
      <article class="info-card"><h3>Keep quick notes now</h3><p>Capture the moment first, then add details, photos, documents, and costs later.</p></article>
      <article class="info-card"><h3>Review history by context</h3><p>Look back by season, animal, place, or report when the bigger picture matters.</p></article>
    </aside>
  </section>

  <section class="section">
    <p class="eyebrow">Daily workflow</p>
    <h2>Move from today’s chores to useful history</h2>
    <p class="section-intro">Open Home to see what needs attention, complete or snooze chores, quick-log what happened, check the calendar for upcoming work, and use reports when you want the bigger picture.</p>
    <div class="workflow-row" aria-label="Homestead Keeper workflow">
      <span>Home</span>
      <span>Complete chores</span>
      <span>Quick Log</span>
      <span>Calendar</span>
      <span>Reports</span>
    </div>
  </section>

  <section class="section">
    <p class="eyebrow">Examples by homestead type</p>
    <h2>Useful whether your place is small, mixed, or growing</h2>
    <FeatureCards cards={homesteadExamples} />
  </section>

  <section class="split-section">
    <div>
      <article class="copy-block">
        <p class="eyebrow">Animals</p>
        <h2>Animals are more than a list</h2>
        <p>Use animal profiles for species and breed details, care reminders, weight history, medical records, vaccination and treatment records, withdrawal warnings, breeding records, offspring creation, pedigree, production entries, photos, and documents.</p>
      </article>
      <article class="copy-block">
        <p class="eyebrow">Inventory</p>
        <h2>Inventory that actually helps</h2>
        <p>Track feed, hay, bedding, medications, vaccines, seeds, canning supplies, fuel, emergency supplies, tools, parts, storage locations, cost and vendor notes, low-stock thresholds, and expiration dates.</p>
      </article>
      <article class="copy-block">
        <p class="eyebrow">Reports</p>
        <h2>Reports for the records you already keep</h2>
        <p>Review Homestead Summary, Logbook, Garden Season, Animal Care, Inventory, Production, Cost Summary, Operations Maintenance, and Property Handoff reports. Pro adds PDF exports, CSV exports, QR label printing, and Apple Calendar export where supported.</p>
      </article>
    </div>
    <aside class="sidebar-stack">
      <!-- TODO: Replace with /public/assets/screenshots/animal-detail.png. -->
      <ScreenshotPlaceholder label="Animal Detail" src={screenshotPaths.animal} />
      <!-- TODO: Replace with /public/assets/screenshots/inventory.png. -->
      <ScreenshotPlaceholder label="Inventory" src={screenshotPaths.inventory} />
      <!-- TODO: Replace with /public/assets/screenshots/reports.png. -->
      <ScreenshotPlaceholder label="Reports" src={screenshotPaths.reports} />
    </aside>
  </section>

  <section class="section">
    <p class="eyebrow">Local-first by design</p>
    <h2>Records should work where the work happens</h2>
    <div class="privacy-grid">
      <article class="privacy-card"><h3>No account required</h3><p>Start keeping records without creating a Homestead Keeper login.</p></article>
      <article class="privacy-card"><h3>No cloud required</h3><p>Day-to-day records, reminders, and reports work without a Homestead Keeper cloud service.</p></article>
      <article class="privacy-card"><h3>Works offline</h3><p>Use the app in barns, gardens, shops, fields, and rural areas with weak signal.</p></article>
      <article class="privacy-card"><h3>User-controlled backups</h3><p>Pro backup and restore tools help you protect or move records using storage you choose.</p></article>
    </div>
  </section>

  <section class="section">
    <p class="eyebrow">Start simple, grow later</p>
    <h2>Use only the areas you need</h2>
    <p class="section-intro">Enable the parts of the Homestead Hub you manage and hide areas you do not need without deleting records. Explore Cedar Ridge demo data first, try real records with Free, then use Pro when your homestead needs unlimited assets, exports, backups, QR labels, documents, and advanced schedules.</p>
    <InternalLinkCards links={[
      { title: 'Explore features', href: '/features', summary: 'See the full feature index for animals, inventory, reports, calendar, finance, production, and property care.' },
      { title: 'Read the setup playbook', href: '/playbook', summary: 'A practical guide for starting small and building useful records over time.' },
      { title: 'Compare Free and Pro', href: '/pricing', summary: 'Review the planned/current pricing model and what Pro unlocks.' },
    ]} />
  </section>

  <section class="section">
    <p class="eyebrow">More screens</p>
    <h2>Screen previews</h2>
    <div class="card-grid">
      <!-- TODO: Replace with /public/assets/screenshots/calendar.png. -->
      <ScreenshotPlaceholder label="Calendar" src={screenshotPaths.calendar} />
      <ScreenshotPlaceholder label="Homestead Hub" />
      <ScreenshotPlaceholder label="Garden Hub" />
      <!-- TODO: Replace with /public/assets/screenshots/settings.png. -->
      <ScreenshotPlaceholder label="Settings" src={screenshotPaths.settings} />
    </div>
  </section>

  <CTA />
</Layout>
