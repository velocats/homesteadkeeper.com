---
import Layout from '../layouts/Layout.astro';
import CTA from '../components/CTA.astro';
import FeatureCard from '../components/FeatureCard.astro';
import PricingCard from '../components/PricingCard.astro';
import ScreenshotFrame from '../components/ScreenshotFrame.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { coreFeatures, managementAreas, pricingTiers, site } from '../data/site';
import { sitePath } from '../utils/paths';

const title = 'Homestead Keeper | Local-First Homestead Management App';
const description = 'Keep your homestead running with a local-first homestead management app for animals, gardens, equipment, inventory, chores, records, reports, and rural property care.';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: site.name,
  applicationCategory: 'LifestyleApplication',
  operatingSystem: 'iOS, iPadOS, macOS',
  description,
};
const workflow = [
  'See today’s chores and reminders.',
  'Log egg count, feed, watering, or a garden note.',
  'Check animal care and health follow-ups.',
  'Record an equipment repair or part replacement.',
  'Update inventory for feed, medicine, seed, fuel, or filters.',
  'Review upcoming seasonal work on the calendar.',
  'Open reports when you need a summary or handoff record.',
];
---

<Layout title={title} description={description} path="/" image="/assets/homepage-screenshot-clean.png" jsonLd={jsonLd}>
  <section class="hero" aria-labelledby="hero-title">
    <div class="hero-copy">
      <p class="eyebrow">Local-first homestead tracker</p>
      <h1 id="hero-title">Keep your homestead running.</h1>
      <p class="hero-lede">Homestead Keeper helps you track animals, gardens, equipment, inventory, chores, records, and reports — from your iPhone, iPad, or Mac.</p>
      <div class="button-row">
        <a class="button primary" href={sitePath('/features')}>See what it tracks</a>
        <a class="button secondary" href={sitePath('/pricing')}>Pricing</a>
      </div>
      <p class="microcopy">Built for backyard homesteads, hobby farms, rural properties, gardens, chicken keepers, and mixed homestead work.</p>
    </div>
    <ScreenshotFrame caption="Today’s work, quick logs, and records without a cloud dashboard in the way." />
  </section>

  <section class="section" aria-labelledby="manage-title">
    <SectionHeader eyebrow="What you can manage" title="Everything you manage, in one calm place." body="Homestead Keeper is a whole-homestead management app — not just an animal tracker, garden notebook, or equipment log." />
    <div class="card-grid compact">
      {managementAreas.slice(0, 12).map(([title, body]) => <FeatureCard title={title} body={body} />)}
    </div>
  </section>

  <section class="split-section soft-panel" aria-labelledby="work-title">
    <div>
      <p class="eyebrow">Built for real homestead work</p>
      <h2 id="work-title">Record the work while the work is happening.</h2>
      <p>Homestead Keeper focuses on practical records: quick logs, recurring reminders, seasonal chores, production tracking, cost notes, inventory changes, photos, and reports you can actually use later.</p>
      <p>It is meant for the messy middle of homesteading — coops, beds, sheds, pumps, pantries, fences, orchards, animals, projects, and the things you meant to write down last week.</p>
    </div>
    <div class="stacked-cards">
      {coreFeatures.slice(2, 8).map(([title, body]) => <FeatureCard title={title} body={body} />)}
    </div>
  </section>

  <section class="section" aria-labelledby="day-title">
    <SectionHeader eyebrow="A day with Homestead Keeper" title="From morning chores to end-of-day notes." body="Use it as a field log, reminder list, inventory tracker, and handoff record without turning your homestead into a spreadsheet project." />
    <ol class="timeline">
      {workflow.map((item) => <li>{item}</li>)}
    </ol>
  </section>

  <section class="split-section" aria-labelledby="local-title">
    <div>
      <p class="eyebrow">Local-first, Apple-first</p>
      <h2 id="local-title">Useful records without cloud complexity.</h2>
      <p>Homestead Keeper is designed for iPhone, iPad, and Mac. Normal day-to-day record keeping does not require a Homestead Keeper web dashboard or hosted account.</p>
      <p>That makes it a better fit for barns, gardens, shops, pump houses, and rural spaces where signal can be unreliable and you just need to capture what happened.</p>
      <a class="text-link" href={sitePath('/privacy')}>Read the local-first privacy notes</a>
    </div>
    <div class="callout-card">
      <h3>Not farm ERP.</h3>
      <p>Homestead Keeper is for homesteaders and small property owners who want better records, reminders, and reports — not a heavy commercial farm system.</p>
    </div>
  </section>

  <section class="section" aria-labelledby="pricing-title">
    <SectionHeader eyebrow="Pricing" title="Simple pricing, finalized before launch." body="The site keeps pricing honest while the App Store release is still being prepared. Exact App Store pricing should only be added when it is final." />
    <div class="pricing-grid">
      {pricingTiers.map((tier) => <PricingCard {...tier} />)}
    </div>
  </section>

  <CTA />
</Layout>
