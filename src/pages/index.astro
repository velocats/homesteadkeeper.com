---
import Layout from '../layouts/Layout.astro';
import CTA from '../components/CTA.astro';
import FeatureCard from '../components/FeatureCard.astro';
import PricingCard from '../components/PricingCard.astro';
import ScreenshotFrame from '../components/ScreenshotFrame.astro';
import AppScreenshot from '../components/AppScreenshot.astro';
import ScreenshotGallery from '../components/ScreenshotGallery.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { calendarScreenshots, coreFeatures, gardenScreenshots, homepageScreenshots, inventoryScreenshots, managementAreas, pricingTiers, reportScreenshots, site, trustPoints } from '../data/site';
import { sitePath } from '../utils/paths';

const title = 'Homestead Keeper | Homestead Records for iPhone, iPad, and Mac';
const description = 'Homestead Keeper is a whole-homestead records app for animals, gardens, garden bed layouts, equipment, inventory, food and pantry, calendar reminders, reports, and rural property care on Apple devices.';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: site.name,
  applicationCategory: 'LifestyleApplication',
  operatingSystem: 'iOS, iPadOS, macOS',
  description,
};
const workflow = [
  'Check today’s chores, overdue reminders, and upcoming seasonal work.',
  'Log eggs, feed, watering, harvests, repairs, inspections, or pantry activity from Field Log actions.',
  'Open garden bed layouts to see what is planted where this season.',
  'Update animal care, production, inventory, equipment service, or property notes.',
  'Review day, week, and month calendar views across the whole homestead.',
  'Export reports, backups, QR labels, and CSV data with Pro when you need records outside the app.',
];
const focusCards = [
  ['No login', 'Use Homestead Keeper without creating a Homestead Keeper web account or managing a separate web dashboard.'],
  ['Data on your devices', 'Your working homestead records live on your Apple devices, with exports and backups under your control.'],
  ['Sync across Apple devices', 'Keep iPhone, iPad, MacBook, Mac mini, and other Macs up to date through Apple iCloud when enabled.'],
  ['Garden bed layouts', 'Plan raised beds, plots, rows, and crop placement by season, then connect layouts to planting and harvest records.'],
  ['Entire homestead records', 'Bring animals, garden, orchard, bees, equipment, property, off-grid, inventory, Food & Pantry, projects, and reports together.'],
  ['Calendar built for chores', 'See harvest windows, animal care, maintenance, warranties, planting dates, overdue work, and seasonal reminders.'],
];
---

<Layout title={title} description={description} path="/" image="/assets/screenshots/homestead-hub.webp" jsonLd={jsonLd}>
  <section class="hero" aria-labelledby="hero-title">
    <div class="hero-copy">
      <p class="eyebrow">Whole-homestead records for Apple devices</p>
      <h1 id="hero-title">Run your homestead from your iPhone, iPad, and Mac.</h1>
      <p class="hero-lede">Homestead Keeper helps you track animals, garden beds, crops, equipment, inventory, Food & Pantry, reminders, calendar work, reports, and property records — without a Homestead Keeper login.</p>
      <div class="button-row">
        <a class="button primary" href={sitePath('/features')}>Explore features</a>
        <a class="button secondary" href={sitePath('/pricing')}>See pricing</a>
      </div>
      <p class="microcopy">No Homestead Keeper account. Data on your Apple devices. Optional iCloud sync across iPhone, iPad, and Mac.</p>
    </div>
    <ScreenshotFrame src="assets/screenshots/homestead-hub.webp" alt="Homestead Keeper Homestead Hub showing Garden, Animals, Property, Inventory, and More to Manage cards." caption="The Homestead Hub brings the major parts of your homestead into one calm place." loading="eager" />
  </section>

  <section class="trust-strip" aria-label="Privacy and sync highlights">
    {trustPoints.map(([title, body]) => (
      <article>
        <strong>{title}</strong>
        <span>{body}</span>
      </article>
    ))}
  </section>

  <section class="section" aria-labelledby="screens-title">
    <SectionHeader eyebrow="Product tour" title="See the app before you install it." body="Every screenshot opens larger in the browser so you can inspect the layout, records, reports, and calendar views." />
    <ScreenshotGallery shots={homepageScreenshots} />
  </section>

  <section class="section" aria-labelledby="focus-title">
    <SectionHeader eyebrow="Why it is different" title="Built for the whole homestead, not just one chore." body="Homestead Keeper combines local records, Apple-device sync, garden planning, calendar reminders, production tracking, and reports for the mixed work that actually happens around a homestead." />
    <div class="card-grid compact">
      {focusCards.map(([title, body]) => <FeatureCard title={title} body={body} />)}
    </div>
  </section>

  <section class="split-section soft-panel" aria-labelledby="beds-title">
    <div>
      <p class="eyebrow">Garden bed layouts</p>
      <h2 id="beds-title">Plan what goes where before the season gets busy.</h2>
      <p>Map garden beds, plots, rows, and crop placement by season. Keep planting dates, harvest records, treatments, notes, and crop history tied back to the garden records you actually use.</p>
      <a class="text-link" href={sitePath('/features/garden')}>See garden features</a>
    </div>
    <div>
      <AppScreenshot {...gardenScreenshots[0]} />
    </div>
  </section>

  <section class="section" aria-labelledby="manage-title">
    <SectionHeader eyebrow="Entire homestead records" title="One record system for everything you manage." body="Start simple with the areas you use today, then add more as your homestead records mature." />
    <div class="card-grid compact">
      {managementAreas.map(([title, body]) => <FeatureCard title={title} body={body} />)}
    </div>
  </section>

  <section class="split-section" aria-labelledby="calendar-title">
    <div>
      <p class="eyebrow">Calendar</p>
      <h2 id="calendar-title">Seasonal work, care reminders, and overdue tasks in one view.</h2>
      <p>Use day, week, and month views to see planting dates, harvest windows, animal care, equipment service, warranties, inspections, recurring chores, and overdue work across the whole homestead.</p>
      <p>Optional Apple Calendar export keeps important homestead dates visible alongside the rest of your day.</p>
      <a class="text-link" href={sitePath('/features/reminders')}>See reminders and calendar</a>
    </div>
    <div class="split-screenshot-grid">
      {calendarScreenshots.map((shot) => <AppScreenshot {...shot} />)}
    </div>
  </section>

  <section class="split-section soft-panel" aria-labelledby="inventory-title">
    <div>
      <p class="eyebrow">Inventory and Food & Pantry</p>
      <h2 id="inventory-title">Know what you have, where it is, and what needs attention.</h2>
      <p>Track feed, seeds, animal health supplies, fuel, filters, pantry goods, expiration dates, low stock, and stored harvests across your homestead.</p>
      <a class="text-link" href={sitePath('/features/inventory')}>See inventory features</a>
    </div>
    <div class="split-screenshot-grid">
      {inventoryScreenshots.map((shot) => <AppScreenshot {...shot} />)}
    </div>
  </section>

  <section class="section" aria-labelledby="reports-title">
    <SectionHeader eyebrow="Reports" title="Turn everyday records into useful summaries." body="Review health, costs, production, inventory, maintenance, warranties, and handoff information without rebuilding the story from scattered notes." />
    <ScreenshotGallery shots={reportScreenshots} />
  </section>

  <section class="section" aria-labelledby="day-title">
    <SectionHeader eyebrow="Daily workflow" title="From morning chores to end-of-day notes." body="Use it as a Field Log, calendar, inventory tracker, production record, and handoff history without turning your homestead into a spreadsheet project." />
    <ol class="timeline">
      {workflow.map((item) => <li>{item}</li>)}
    </ol>
  </section>

  <section class="section" aria-labelledby="pricing-title">
    <SectionHeader eyebrow="Pricing" title="Try it free. Upgrade when your records grow." body="Free includes up to 20 total items. Pro unlocks unlimited items plus exports, backups, QR labels, and advanced tools." />
    <div class="pricing-grid">
      {pricingTiers.map((tier) => <PricingCard {...tier} />)}
    </div>
  </section>

  <CTA title="Ready to bring your homestead records together?" body="Track the animals, beds, equipment, supplies, places, calendar work, and reports that keep your homestead running." primaryLabel="Explore features" primaryHref="/features" secondaryLabel="Read FAQ" secondaryHref="/faq" />
</Layout>
