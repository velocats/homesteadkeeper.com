---
import Layout from '../layouts/Layout.astro';
import CTA from '../components/CTA.astro';
import { site } from '../data/site';

const title = 'Support | Homestead Keeper';
const description = 'Contact Homestead Keeper support for help, bug reports, feature requests, backup questions, and local-first homestead app questions.';
---

<Layout title={title} description={description} path="/support">
  <section class="page-hero narrow">
    <p class="eyebrow">Support</p>
    <h1>Need help with Homestead Keeper?</h1>
    <p class="lede">For support, bug reports, feature requests, backup questions, or practical workflow feedback, email the support address below.</p>
    <p><a class="button primary" href={`mailto:${site.supportEmail}`}>Email {site.supportEmail}</a></p>
  </section>

  <section class="section">
    <div class="card-grid">
      <article class="card"><h3>Bug reports</h3><p>Include your device, app version, what you expected, and what happened.</p></article>
      <article class="card"><h3>Feature requests</h3><p>Describe the homestead workflow you are trying to support and the record you need to keep.</p></article>
      <article class="card"><h3>Backup help</h3><p>Ask before deleting the app, wiping a device, or moving important local records.</p></article>
    </div>
  </section>

  <CTA primaryLabel="Read FAQ" primaryHref="/faq" secondaryLabel="View features" secondaryHref="/features" />
</Layout>
