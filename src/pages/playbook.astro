---
import Layout from '../layouts/Layout.astro';
import CTA from '../components/CTA.astro';
import InternalLinkCards from '../components/InternalLinkCards.astro';

const sections = [
  ['Start with what needs attention every week', 'Begin with the chores and records that already live in your head: feeding, watering, coop cleaning, equipment checks, harvest notes, medication follow-ups, and seasonal property work.'],
  ['Name your homestead and add places', 'Rename “My Homestead,” then add real places such as Barn, Chicken Coop, Garden Beds, Apiary, Workshop, Pantry, Equipment Shed, and Pasture.'],
  ['Turn on your main areas', 'Start with the Homestead Hub areas you use now, such as Animals, Garden, Equipment, Orchard, Bees, Food & Pantry, Off-grid, Emergency Prep, Forestry, Weather & Seasons, and Inventory. Hide the rest until you need them.'],
  ['Map garden beds and crops', 'Create garden bed layouts, choose crops, and connect planting records, care notes, and harvest history to the places where things are actually growing.'],
  ['Add animals and groups', 'Start with the animals you handle most often: a chicken flock, rabbit breeding pair, goat herd, sheep group, bees, or individual animals with medical, breeding, weight, production, and care records.'],
  ['Add inventory items that can run out', 'Track feed, hay, bedding, medications, vaccines, seeds, canning supplies, fuel, filters, emergency supplies, tools, parts, and other items that create stress when they are missing.'],
  ['Use Field Log for anything unusual', 'Capture what happened while it is fresh: a treatment, broken gate, low feed bin, odd behavior, first egg, milk change, harvest note, expense, or repair. Rich detail can come later.'],
  ['Review Calendar weekly', 'Use Calendar to see what is overdue, what is due today, and what is coming up across care, animals, breeding, production, garden, equipment, and inventory.'],
  ['Review Reports monthly or seasonally', 'Reports turn small records into useful summaries: Homestead Summary, Animal Care, Garden Season, Inventory, Production, Cost, Operations Maintenance, and Property Handoff.'],
  ['Try Cedar Ridge demo first if unsure', 'Cedar Ridge demo data gives you a safe sample homestead to explore before adding your own records. Free also supports up to 20 total items.'],
];
---

<Layout
  title="Playbook | Homestead Keeper"
  description="Start simple with Homestead Keeper: name your homestead, add places, map garden beds, add animals and inventory, use Field Log entries, Calendar reviews, Reports, and Cedar Ridge demo data."
  path="/playbook"
>
  <section class="page-hero">
    <p class="eyebrow">Playbook</p>
    <h1>Start simple: a practical Homestead Keeper setup guide</h1>
    <p class="lede">Homestead Keeper works best when you begin with the records that reduce stress right away, then add detail as your homestead grows.</p>
  </section>

  <section class="split-section">
    <div>
      {sections.map(([title, body], index) => (
        <article class="copy-block">
          <p class="eyebrow">Step {index + 1}</p>
          <h2>{title}</h2>
          <p>{body}</p>
        </article>
      ))}
    </div>
    <aside class="sidebar-stack">
      <article class="info-card">
        <p class="eyebrow">Best first move</p>
        <h3>Pick twenty real items or fewer</h3>
        <p>Free supports up to 20 total items, which is enough to test the daily rhythm before committing your whole homestead.</p>
      </article>
      <article class="info-card">
        <p class="eyebrow">Working style</p>
        <h3>Fast capture first</h3>
        <p>Use Field Log entries during chores, then add documents, photos, costs, and structured details when you have more time.</p>
      </article>
      <article class="info-card">
        <p class="eyebrow">Apple devices</p>
        <h3>Start on iPhone, review on Mac</h3>
        <p>Use iCloud sync to keep records current across your iPhone, iPad, MacBook, Mac mini, and other Macs when enabled.</p>
      </article>
    </aside>
  </section>

  <section class="section">
    <p class="eyebrow">Next steps</p>
    <h2>Build from the records you already keep</h2>
    <InternalLinkCards links={[
      { title: 'Animal records', href: '/features/animals', summary: 'Profiles, care reminders, medical records, breeding, pedigree, production, and reports.' },
      { title: 'Garden bed layouts', href: '/features/garden', summary: 'Map beds, crops, seasonal plans, planting records, and harvest history.' },
      { title: 'Reports and exports', href: '/features/reports', summary: 'Review seasonal patterns and export PDF or CSV records with Pro.' },
    ]} />
  </section>

  <CTA />
</Layout>
