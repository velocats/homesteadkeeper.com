---
import Layout from '../layouts/Layout.astro';
import CTA from '../components/CTA.astro';
import InternalLinkCards from '../components/InternalLinkCards.astro';

const featureGroups = [
  {
    title: 'Home & Daily Chores',
    items: ['Home dashboard', 'Overdue, due today, and upcoming work', 'Recurring care reminders', 'Custom recurrence', 'Snooze', 'Completion history', 'Quick logging'],
  },
  {
    title: 'Homestead Hub',
    items: ['Animals', 'Garden', 'Property', 'Equipment', 'Orchard', 'Bees', 'Food Preservation', 'Off-grid', 'Weather & Seasons', 'Wildlife & Pests', 'Forestry', 'Emergency Prep', 'Projects', 'Family & Education', 'Farm Business', 'Inventory'],
    note: 'Enable the areas you use and hide areas you do not need without deleting records.',
  },
  {
    title: 'Animals',
    items: ['Individual animals', 'Flocks, herds, and groups', 'Species and breed fields', 'Photos', 'Records timeline', 'Care reminders', 'Medical', 'Weight', 'Production', 'Breeding', 'Pedigree'],
  },
  {
    title: 'Medical / Treatment Records',
    items: ['Vaccination', 'Medication', 'Treatment', 'Deworming', 'Illness or injury', 'Vet visit', 'Lab test', 'Health certificate', 'Next-due reminders', 'Withdrawal tracking and warnings'],
    note: 'Homestead Keeper keeps records. It does not provide veterinary advice.',
  },
  {
    title: 'Breeding & Pedigree',
    items: ['Breeding records', 'Due dates', 'Incubation and lockdown', 'Breeding groups', 'Additional dams or hens', 'Birth or hatch completion', 'Offspring creation', 'Sire and dam links', 'Three-generation pedigree', 'Tattoo and registration fields', 'Off-farm parent names'],
  },
  {
    title: 'Production',
    items: ['Eggs', 'Milk', 'Honey', 'Wool and fiber', 'Meat', 'Wax', 'Custom products', 'Stored, sold, used, fed, or discarded destinations', 'Sale amount and buyer', 'Inventory link', 'Photo attachment', 'Production reports', 'CSV export', 'Withdrawal warning when applicable'],
  },
  {
    title: 'Inventory',
    items: ['Feed, hay, and bedding', 'Animal health items', 'Seeds and garden materials', 'Canning supplies', 'Fuel and propane', 'Emergency supplies', 'Tools and parts', 'Building materials', 'Quantity and unit', 'Low-stock thresholds', 'Expiration dates', 'Storage locations', 'Purchase, cost, and vendor notes', 'Home alerts'],
  },
  {
    title: 'Financial Records',
    items: ['Income', 'Expenses', 'Categories', 'Vendor or customer', 'Linked animal, item, or project when applicable', 'Simple monthly and yearly summaries', 'CSV export'],
    note: 'Useful for homestead records, but not a full accounting or tax software replacement.',
  },
  {
    title: 'Calendar',
    items: ['All', 'Care', 'Animals', 'Breeding', 'Production', 'Garden', 'Equipment', 'Inventory', 'Medical reminders through care', 'Day and week views', 'Context titles'],
  },
  {
    title: 'Reports & Exports',
    items: ['In-app reports', 'PDF reports', 'CSV exports', 'Apple Calendar export', 'QR labels', 'Property Handoff', 'Garden Season', 'Animal Care', 'Inventory', 'Production', 'Financial and cost summaries'],
  },
  {
    title: 'Data, Backup & Privacy',
    items: ['Local-first records', 'Backup and restore with Pro', 'User-controlled backups', 'No account required', 'No cloud required for day-to-day use'],
  },
];
---

<Layout
  title="Features | Homestead Keeper"
  description="Explore Homestead Keeper features for daily chores, animals, medical records, breeding, pedigree, production, inventory, finances, calendar, reports, exports, backups, and local-first privacy."
  path="/features"
>
  <section class="page-hero">
    <p class="eyebrow">Feature overview</p>
    <h1>A practical homestead record keeping app</h1>
    <p class="lede">Homestead Keeper helps serious backyard homesteaders, hobby farmers, rural property owners, and small mixed-animal operations keep local-first records without turning the homestead into enterprise farm software.</p>
  </section>

  <section class="section">
    <div class="report-grid">
      {featureGroups.map((group) => (
        <article class="report-card feature-index-card">
          <h2>{group.title}</h2>
          <ul>
            {group.items.map((item) => <li>{item}</li>)}
          </ul>
          {group.note && <p>{group.note}</p>}
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <p class="eyebrow">Deep dives</p>
    <h2>Explore core workflows</h2>
    <InternalLinkCards links={[
      { title: 'Animals', href: '/features/animals', summary: 'Animal profiles, care, medical records, breeding, pedigree, production, documents, and reports.' },
      { title: 'Inventory', href: '/features/inventory', summary: 'Low-stock alerts, expiration dates, storage locations, vendor notes, and Home alerts.' },
      { title: 'Reports', href: '/features/reports', summary: 'Homestead Summary, Logbook, Property Handoff, PDF reports, CSV exports, and QR labels.' },
    ]} />
  </section>

  <CTA />
</Layout>
