---
import Layout from '../layouts/Layout.astro';
import CTA from '../components/CTA.astro';
import FeatureCard from '../components/FeatureCard.astro';
import ScreenshotFrame from '../components/ScreenshotFrame.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { coreFeatures, managementAreas } from '../data/site';

const title = 'Features | Homestead Keeper';
const description = 'Explore Homestead Keeper features for animals, gardens, orchards, bees, equipment maintenance, property systems, inventory, calendar reminders, reports, exports, and local-first homestead records.';
const groups = [
  ['Animals', ['Animal profiles', 'Care reminders', 'Health notes', 'Breeding and pedigree', 'Production records', 'Weights, photos, and documents']],
  ['Garden, crops, and seeds', ['Beds and planting areas', 'Crops and varieties', 'Seed starts and planting dates', 'Watering and pest notes', 'Harvest logs', 'Planting schedules and seasonal timing']],
  ['Orchard', ['Fruit trees and berries', 'Pruning and spray notes', 'Fertilizing reminders', 'Harvest history', 'Seasonal care', 'Long-term perennial records']],
  ['Bees', ['Hive inspections', 'Queen notes', 'Feeding and treatments', 'Splits and swarms', 'Honey harvests', 'Hive equipment records']],
  ['Equipment and maintenance', ['Repairs', 'Service reminders', 'Parts and filters', 'Fuel notes', 'Manuals and warranties', 'Maintenance history']],
  ['Property systems', ['Places', 'Fences and gates', 'Wells and pumps', 'Irrigation and water systems', 'Buildings and storage', 'Storm damage and repairs']],
  ['Off-grid systems', ['Solar and batteries', 'Generators', 'Propane', 'Water storage', 'Backup power', 'Seasonal checks']],
  ['Inventory', ['Feed and hay', 'Medicine and vaccines', 'Seeds and soil inputs', 'Fuel and filters', 'Pantry and preservation supplies', 'Thresholds and expiration dates']],
  ['Calendar', ['Today view', 'Overdue work', 'Recurring chores', 'Seasonal tasks', 'Animal care follow-ups', 'Maintenance reminders']],
  ['Reports and exports', ['Homestead summary', 'Cost summary', 'Logbook', 'Animal care history', 'Inventory report', 'Property handoff report']],
  ['Demo homestead', ['Cedar Ridge demo data', 'Example animals and places', 'Sample garden records', 'Sample reminders', 'Sample reports', 'A safe way to explore before setup']],
  ['Apple device support', ['iPhone', 'iPad', 'Mac', 'Local-first design', 'No required web dashboard', 'Practical offline-friendly workflows']],
];
---

<Layout title={title} description={description} path="/features" image="/assets/homepage-screenshot-clean.png">
  <section class="page-hero">
    <p class="eyebrow">Features</p>
    <h1>A whole-homestead app, not another single-purpose tracker.</h1>
    <p class="lede">Homestead Keeper brings animals, gardens, orchards, bees, equipment, inventory, places, reminders, reports, and rural property care into one practical Apple app.</p>
  </section>

  <section class="split-section">
    <div>
      <p class="eyebrow">Core workflow</p>
      <h2>Track what happened, what it cost, and what is coming up next.</h2>
      <p>Use Homestead Keeper to capture records in the moment, organize them by place or asset, and review the history later through reports and summaries.</p>
    </div>
    <ScreenshotFrame />
  </section>

  <section class="section">
    <SectionHeader eyebrow="Foundation" title="Core app areas" body="These are the building blocks that make the app useful across mixed homestead responsibilities." />
    <div class="card-grid">
      {coreFeatures.map(([title, body]) => <FeatureCard title={title} body={body} />)}
    </div>
  </section>

  <section class="section">
    <SectionHeader eyebrow="Complete overview" title="What Homestead Keeper is designed to cover" body="The website should present the app as a whole-homestead management tool, including less-obvious areas like forestry, emergency prep, weather, projects, and food preservation." />
    <div class="card-grid compact">
      {managementAreas.map(([title, body]) => <FeatureCard title={title} body={body} />)}
    </div>
  </section>

  <section class="section">
    <SectionHeader eyebrow="Detailed feature map" title="Records by area" body="A practical view of the records and workflows planned or represented in the product direction." />
    <div class="feature-map">
      {groups.map(([title, items]) => (
        <article class="map-card">
          <h3>{title}</h3>
          <ul class="check-list">
            {(items as string[]).map((item) => <li>{item}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <CTA title="Want the simple version?" body="Start with the Home dashboard, Places, Animals, Garden, Inventory, Calendar, and Reports — then grow into the deeper areas as your homestead records mature." />
</Layout>
