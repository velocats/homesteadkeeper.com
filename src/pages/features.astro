---
import Layout from '../layouts/Layout.astro';
import CTA from '../components/CTA.astro';
import FeatureCard from '../components/FeatureCard.astro';
import ScreenshotFrame from '../components/ScreenshotFrame.astro';
import AppScreenshot from '../components/AppScreenshot.astro';
import ScreenshotGallery from '../components/ScreenshotGallery.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { animalScreenshots, calendarScreenshots, coreFeatures, equipmentScreenshots, gardenScreenshots, inventoryScreenshots, managementAreas, productTourScreenshots, reportScreenshots } from '../data/site';

const title = 'Features | Homestead Keeper';
const description = 'Explore Homestead Keeper features for whole-homestead records, garden bed layouts, animals, orchards, bees, equipment, property, off-grid systems, Food & Pantry, inventory, calendar reminders, reports, exports, and Apple device sync.';
const groups = [
  ['Garden beds, crops, and seeds', ['Visual bed and plot layouts', 'Seasonal crop placement', 'Crops and varieties', 'Seed starts and planting dates', 'Harvest logs and yields', 'Planting schedules and seasonal timing']],
  ['Animals', ['Animal profiles and groups', 'Care reminders', 'Health notes', 'Breeding and pedigree', 'Production records', 'Weights, photos, and documents']],
  ['Calendar and reminders', ['Day, week, and month views', 'Overdue work', 'Recurring chores', 'Seasonal tasks', 'Animal care follow-ups', 'Maintenance and harvest windows']],
  ['Equipment and maintenance', ['Repairs', 'Service reminders', 'Parts and filters', 'Fuel notes', 'Manuals and warranties', 'Maintenance history']],
  ['Property systems', ['Places', 'Fences and gates', 'Wells and pumps', 'Irrigation and water systems', 'Buildings and storage', 'Storm damage and repairs']],
  ['Food & Pantry', ['Canned goods', 'Frozen food', 'Dehydrated food', 'Fermented batches', 'Pantry items', 'Root cellar storage']],
  ['Inventory', ['Feed and hay', 'Medicine and vaccines', 'Seeds and soil inputs', 'Fuel and filters', 'Pantry and preservation supplies', 'Thresholds and expiration dates']],
  ['Orchard', ['Fruit trees and berries', 'Pruning and spray notes', 'Fertilizing reminders', 'Harvest history', 'Seasonal care', 'Long-term perennial records']],
  ['Bees', ['Hive inspections', 'Queen notes', 'Feeding and treatments', 'Splits and swarms', 'Honey harvests', 'Hive equipment records']],
  ['Off-grid systems', ['Solar and batteries', 'Generators', 'Propane', 'Water storage', 'Backup power', 'Seasonal checks']],
  ['Reports and exports', ['Homestead summary', 'Cost summary', 'Logbook', 'Animal care history', 'Inventory report', 'Property handoff report']],
  ['Apple device support', ['iPhone', 'iPad', 'Mac', 'No Homestead Keeper login', 'iCloud sync across Apple devices', 'Offline-friendly workflows']],
];
---

<Layout title={title} description={description} path="/features" image="/assets/screenshots/homestead-hub.webp">
  <section class="page-hero">
    <p class="eyebrow">Features</p>
    <h1>A whole-homestead app, not another single-purpose tracker.</h1>
    <p class="lede">Homestead Keeper brings animals, garden bed layouts, crops, orchards, bees, equipment, inventory, Food & Pantry, places, reminders, reports, and rural property care into one practical Apple app.</p>
  </section>

  <section class="split-section">
    <div>
      <p class="eyebrow">Core workflow</p>
      <h2>Track what happened, what it cost, and what is coming up next.</h2>
      <p>Use Homestead Keeper to capture records in the moment, organize them by place or item, and review the history later through calendar views, reports, summaries, and exports.</p>
      <p>No Homestead Keeper login is required. Records live on your Apple devices and can sync across iPhone, iPad, and Mac through iCloud when enabled.</p>
    </div>
    <ScreenshotFrame src="assets/screenshots/homestead-hub.webp" alt="Homestead Keeper Homestead Hub showing the major areas of the app." caption="The Homestead Hub keeps the mixed work of a homestead organized." />
  </section>

  <section class="section">
    <SectionHeader eyebrow="Foundation" title="Core app areas" body="These are the building blocks that make the app useful across mixed homestead responsibilities." />
    <div class="card-grid">
      {coreFeatures.map(([title, body]) => <FeatureCard title={title} body={body} />)}
    </div>
  </section>

  <section class="split-section soft-panel">
    <div>
      <p class="eyebrow">Garden bed layouts</p>
      <h2>Make the garden visual.</h2>
      <p>Plan beds and plots, place crops into layouts, and track what was planted in each season. Then connect the plan to planting dates, harvests, reminders, and production history.</p>
    </div>
    <div class="split-screenshot-grid">
      {gardenScreenshots.map((shot) => <AppScreenshot {...shot} />)}
    </div>
  </section>

  <section class="section" aria-labelledby="tour-title">
    <SectionHeader eyebrow="Screenshots" title="A tour through the real app." body="Click any screenshot to open it larger in your browser. These images show layouts, calendar views, animal records, equipment service, inventory, reports, and production tracking." />
    <ScreenshotGallery shots={productTourScreenshots} />
  </section>

  <section class="section">
    <SectionHeader eyebrow="Complete overview" title="What Homestead Keeper is designed to cover" body="The app is meant to cover the whole mixed homestead, including less-obvious areas like forestry, emergency prep, off-grid systems, projects, and Food & Pantry." />
    <div class="card-grid compact">
      {managementAreas.map(([title, body]) => <FeatureCard title={title} body={body} />)}
    </div>
  </section>

  <section class="split-section" aria-labelledby="calendar-screen-title">
    <div>
      <p class="eyebrow">Calendar and timelines</p>
      <h2 id="calendar-screen-title">Plan around seasons, chores, and animal milestones.</h2>
      <p>Calendar and timeline views make future work easier to see: breeding milestones, garden timing, harvest windows, frost dates, and recurring chores.</p>
    </div>
    <div class="split-screenshot-grid">
      {calendarScreenshots.map((shot) => <AppScreenshot {...shot} />)}
    </div>
  </section>

  <section class="split-section soft-panel" aria-labelledby="records-screen-title">
    <div>
      <p class="eyebrow">Animals, equipment, and inventory</p>
      <h2 id="records-screen-title">Records stay attached to the things you manage.</h2>
      <p>Each animal, piece of equipment, and supply can carry its own history, production, care, status, and Field Log entries.</p>
    </div>
    <div class="split-screenshot-grid">
      {[...animalScreenshots, ...equipmentScreenshots, ...inventoryScreenshots].map((shot) => <AppScreenshot {...shot} />)}
    </div>
  </section>

  <section class="section" aria-labelledby="reports-screen-title">
    <SectionHeader eyebrow="Reports" title="See the story your records are telling." body="Homestead Keeper turns routine logs into summaries for health, costs, maintenance, warranties, inventory, and production." />
    <ScreenshotGallery shots={reportScreenshots} />
  </section>

  <section class="section">
    <SectionHeader eyebrow="Detailed feature map" title="Records by area" body="A practical view of the records and workflows represented in the product direction." />
    <div class="feature-map">
      {groups.map(([title, items]) => (
        <article class="map-card">
          <h3>{title}</h3>
          <ul class="check-list">
            {(items as string[]).map((item) => <li>{item}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <CTA title="Want the simple version?" body="Start with Home, Places, Garden, Animals, Inventory, Calendar, and Reports — then grow into the deeper areas as your homestead records mature." />
</Layout>
